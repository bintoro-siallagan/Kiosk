// Mini sparkline chart
function Sparkline({ data, color, height=40 }) {
  if (!data?.length) return null;
  const max = Math.max(...data, 1);
  const w = 120, h = height;
  const pts = data.map((v,i) => `${(i/(data.length-1))*w},${h - (v/max)*h*0.85}`).join(" ");
  return (
    <svg width={w} height={h} style={{overflow:"visible"}}>
      <defs>
        <linearGradient id={`sg${color.replace("#","")}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={color} stopOpacity="0.3"/>
          <stop offset="100%" stopColor={color} stopOpacity="0"/>
        </linearGradient>
      </defs>
      <polygon points={`0,${h} ${pts} ${w},${h}`} fill={`url(#sg${color.replace("#","")})`}/>
      <polyline points={pts} fill="none" stroke={color} strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/>
      <circle cx={data.map((v,i)=>[(i/(data.length-1))*w, h-(v/max)*h*0.85]).pop()[0]}
              cy={data.map((v,i)=>[(i/(data.length-1))*w, h-(v/max)*h*0.85]).pop()[1]}
              r="3" fill={color}/>
    </svg>
  );
}

// Donut chart
function Donut({ segments, size=80 }) {
  const r = 28, cx = size/2, cy = size/2, circ = 2*Math.PI*r;
  const total = segments.reduce((s,g)=>s+g.val,0)||1;
  let offset = 0;
  return (
    <svg width={size} height={size}>
      <circle cx={cx} cy={cy} r={r} fill="none" stroke="#1a1a2e" strokeWidth="10"/>
      {segments.map((seg,i) => {
        const dash = (seg.val/total)*circ;
        const el = <circle key={i} cx={cx} cy={cy} r={r} fill="none" stroke={seg.color}
          strokeWidth="10" strokeDasharray={`${dash} ${circ-dash}`}
          strokeDashoffset={-offset} strokeLinecap="round"
          style={{transform:"rotate(-90deg)",transformOrigin:`${cx}px ${cy}px`}}/>;
        offset += dash;
        return el;
      })}
    </svg>
  );
}

// Order kanban card
function OrderCard({ order, onStatus, compact }) {
  const st = STATUS[order.status];
  const mins = Math.floor((Date.now()-order.time)/60000);
  const urgent = order.status === "waiting" && mins > 5;
  return (
    <div style={{
      background: urgent ? "rgba(248,113,113,0.05)" : "#0d1117",
      border: `1px solid ${urgent ? "#F87171" : st.color}22`,
      borderLeft: `3px solid ${st.color}`,
      borderRadius: 10, padding: compact?"10px 12px":"14px 16px",
      marginBottom: 8, cursor:"pointer", transition:"all 0.15s",
    }}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
        <div style={{display:"flex",alignItems:"center",gap:8}}>
          <span style={{fontFamily:"'Space Mono',monospace",fontSize:13,fontWeight:700,color:"#fff"}}>#{order.id}</span>
          {urgent && <span style={{fontSize:9,background:"#F87171",color:"#fff",borderRadius:4,padding:"1px 5px",fontWeight:700,letterSpacing:1}}>LATE</span>}
        </div>
        <span style={{fontSize:11,color:"#555"}}>{fAgo(order.time)}</span>
      </div>
      <div style={{fontSize:12,color:"#888",marginBottom:8}}>
        {order.type==="dine"?`🪑 Meja ${order.table}`:"🛍️ Bawa Pulang"} · {fIDR(order.total)}
      </div>
      {!compact && (
        <div style={{fontSize:11,color:"#666",marginBottom:10,lineHeight:1.6}}>
          {order.items.map(i=>`${i.e}${i.n}×${i.q}`).join(" · ")}
        </div>
      )}
      <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
        {order.status==="waiting" && (
          <button onClick={()=>onStatus(order.id,"preparing")} style={btnStyle("#38BDF8")}>👨‍🍳 Proses</button>
        )}
        {order.status==="preparing" && (
          <button onClick={()=>onStatus(order.id,"ready")} style={btnStyle("#34D399")}>✅ Siap</button>
        )}
        {order.status==="ready" && (
          <button onClick={()=>onStatus(order.id,"completed")} style={btnStyle("#6B7280")}>🏁 Selesai</button>
        )}
        {!["completed","cancelled"].includes(order.status) && (
          <button onClick={()=>onStatus(order.id,"cancelled")} style={btnStyle("#F87171","transparent")}>✕</button>
        )}
      </div>
    </div>
  );
}

