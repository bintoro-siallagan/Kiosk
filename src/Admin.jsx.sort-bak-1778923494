                    <div key={item.id} style={{background:"#0d1117",border:`1px solid ${item.avail?"#161b22":"#F8717122"}`,borderRadius:12,padding:"14px",opacity:item.avail?1:0.6,transition:"all 0.2s"}}>
                      <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:10}}>
