import { useState, useEffect, useRef } from "react";

const API_BASE = import.meta.env.VITE_API_URL || "http://localhost:3011";
const WS_URL = API_BASE.replace(/^http/, "ws");

// Stages for post-payment tracking
const STAGES = [
  { key: "waiting",   label: "Diterima",     emoji: "📝", color: "#94A3B8" },
  { key: "preparing", label: "Disiapkan",    emoji: "👨‍🍳", color: "#F59E0B" },
  { key: "ready",     label: "Siap Diambil", emoji: "🔔", color: "#10B981" },
  { key: "completed", label: "Selesai",      emoji: "✅", color: "#22C55E" },
];

const fmt = (n) => "Rp " + (n || 0).toLocaleString("id-ID");

export default function POSCDS() {
  const [mode, setMode] = useState("idle"); // idle | cart | qris | success | tracking
  const [state, setState] = useState({});
  const [connStatus, setConnStatus] = useState("connecting");
  const wsRef = useRef(null);
  const reconnectTimerRef = useRef(null);

  // Auto-fetch order updates if tracking
  useEffect(() => {
    if (mode !== "tracking" || !state.completedOrder?.id) return;
    let timer;
    const fetchOrder = async () => {
      try {
        const r = await fetch(`${API_BASE}/api/orders/${state.completedOrder.id}`);
        if (r.ok) {
          const data = await r.json();
          setState(prev => ({...prev, completedOrder: data}));
        }
      } catch {}
    };
    fetchOrder();
    timer = setInterval(fetchOrder, 5000);
    return () => clearInterval(timer);
  }, [mode, state.completedOrder?.id]);

  // WebSocket connection with reconnect
  useEffect(() => {
    let mounted = true;

    const connect = () => {
      if (!mounted) return;
      setConnStatus("connecting");
      try {
        const ws = new WebSocket(WS_URL);
        wsRef.current = ws;

        ws.onopen = () => {
          if (!mounted) return;
          setConnStatus("connected");
          console.log("[CDS] WebSocket connected");
        };

        ws.onmessage = (msg) => {
          if (!mounted) return;
          try {
            const parsed = JSON.parse(msg.data);
            const event = parsed.event || parsed.type;
            const data = parsed.data || parsed.payload || {};
            handleEvent(event, data);
          } catch (e) {
            console.warn("[CDS] Failed to parse:", e);
          }
        };

        ws.onerror = (err) => {
          console.warn("[CDS] WS error:", err);
        };

        ws.onclose = () => {
          if (!mounted) return;
          setConnStatus("disconnected");
          console.log("[CDS] WS closed, reconnecting in 3s...");
          reconnectTimerRef.current = setTimeout(connect, 3000);
        };
      } catch (e) {
        if (!mounted) return;
        reconnectTimerRef.current = setTimeout(connect, 3000);
      }
    };

    connect();

    return () => {
      mounted = false;
      if (reconnectTimerRef.current) clearTimeout(reconnectTimerRef.current);
      if (wsRef.current) {
        wsRef.current.onclose = null;
        wsRef.current.close();
      }
    };
  }, []);

  const handleEvent = (event, data) => {
    switch (event) {
      case "pos:cart_update":
        setState(prev => ({...prev, ...data}));
        if (data.cart && data.cart.length > 0) setMode("cart");
        else if (mode !== "idle") setMode("idle");
        break;

      case "pos:payment_qris":
        setState(prev => ({...prev, qris: data}));
        setMode("qris");
        break;

      case "pos:order_complete":
        setState(prev => ({...prev, completedOrder: data.order || data}));
        setMode("success");
        setTimeout(() => setMode("tracking"), 4000);
        break;

      case "pos:idle":
      case "pos:reset":
        setState({});
        setMode("idle");
        break;

      case "order:updated":
        // Order status changed in DB (KDS workflow)
        setState(prev => {
          if (prev.completedOrder && data.id === prev.completedOrder.id) {
            return {...prev, completedOrder: data};
          }
          return prev;
        });
        break;
    }
  };

  // Render based on mode
  return (
    <div style={S.root}>
      <ConnIndicator status={connStatus} />
      {mode === "idle" && <CDSIdle />}
      {mode === "cart" && <CDSCart state={state} />}
      {mode === "qris" && <CDSQR state={state} />}
      {mode === "success" && <CDSSuccess state={state} />}
      {mode === "tracking" && <CDSTracking state={state} />}
    </div>
  );
}

function ConnIndicator({ status }) {
  const color = status === "connected" ? "#10B981" : status === "connecting" ? "#F59E0B" : "#EF4444";
  return (
    <div style={{...S.conn, color, borderColor:color}}>
      <span style={{...S.connDot, background:color}}/> {status}
    </div>
  );
}

function CDSIdle() {
  return (
    <div style={S.center}>
      <div style={S.logo}>☕</div>
      <div style={S.brand}>BINTORO</div>
      <div style={S.idleTagline}>Selamat datang!</div>
      <div style={S.idleHint}>Pesanan Anda akan ditampilkan di sini</div>
      <div style={S.idleBlinker}>● ● ●</div>
    </div>
  );
}

function CDSCart({ state }) {
  const cart = state.cart || [];
  const subtotal = state.subtotal ?? cart.reduce(
    (s, c) => s + ((c.price || 0) + (c.addonTotal || 0)) * c.qty, 0
  );
  const customerName = state.order?.customerName;
  const orderType = state.order?.type;

  return (
    <>
      <header style={S.header}>
        <div style={S.headerLeft}>
          <span style={S.logoSmall}>☕</span>
          <span style={S.brandSmall}>BINTORO</span>
        </div>
        <div style={S.headerRight}>
          {orderType && <span style={S.tag}>{orderType === "dine-in" ? "🍽️ Dine-in" : "🛍️ Take-away"}</span>}
        </div>
      </header>

      <main style={S.cartMain}>
        <div style={S.cartTitle}>
          Pesanan Anda
          {customerName && <span style={S.customerName}>· {customerName}</span>}
        </div>

        <div style={S.cartList}>
          {cart.map(item => {
            const lineTotal = ((item.price || 0) + (item.addonTotal || 0)) * item.qty;
            const toppings = item.addons?.toppings || [];
            return (
              <div key={item.cartKey || item.id} style={S.cartItem}>
                <div style={S.itemEmoji}>{item.emoji || "🍴"}</div>
                <div style={S.itemBody}>
                  <div style={S.itemName}>{item.name}</div>
                  {toppings.length > 0 && (
                    <div style={S.itemAddons}>
                      {toppings.map((t, i) => (
                        <span key={i} style={S.addonTag}>+ {t.name}</span>
                      ))}
                    </div>
                  )}
                </div>
                <div style={S.itemQty}>{item.qty}x</div>
                <div style={S.itemPrice}>{fmt(lineTotal)}</div>
              </div>
            );
          })}
        </div>
      </main>

      <footer style={S.cartFooter}>
        <div>
          <div style={S.subLabel}>SUBTOTAL</div>
          <div style={S.subAmount}>{fmt(subtotal)}</div>
        </div>
        <div style={S.taxNote}>PPN 10% included</div>
      </footer>
    </>
  );
}

function CDSQR({ state }) {
  const qris = state.qris || {};
  const amount = qris.amount || state.subtotal || 0;
  const qrUrl = qris.qrCode || qris.qrUrl || qris.actions?.[0]?.url;

  return (
    <>
      <header style={S.header}>
        <div style={S.headerLeft}>
          <span style={S.logoSmall}>☕</span>
          <span style={S.brandSmall}>BINTORO</span>
        </div>
        <div style={S.tag}>💳 QRIS Payment</div>
      </header>

      <main style={S.qrMain}>
        <div style={S.qrTitle}>Scan QR untuk Bayar</div>

        <div style={S.qrFrame}>
          {qrUrl ? (
            <img src={qrUrl} alt="QR Code" style={S.qrImage} />
          ) : (
            <div style={S.qrLoading}>
              <div style={S.loader}>⏳</div>
              <div>Generating QR...</div>
            </div>
          )}
        </div>

        <div style={S.qrHint}>
          Buka aplikasi e-wallet atau mobile banking<br/>
          (GoPay, OVO, DANA, ShopeePay, dst)
        </div>

        <div style={S.qrAmountBox}>
          <span style={S.subLabel}>TOTAL BAYAR</span>
          <span style={S.qrAmount}>{fmt(amount)}</span>
        </div>
      </main>
    </>
  );
}

function CDSSuccess({ state }) {
  const order = state.completedOrder || {};
  return (
    <div style={S.center}>
      <div style={S.successCheck}>✅</div>
      <div style={S.successTitle}>Pembayaran Berhasil!</div>
      <div style={S.successOrderId}>Order #{order.id || ""}</div>
      <div style={S.successAmount}>{fmt(order.total || 0)}</div>
      <div style={S.successThanks}>Terima kasih 🙏</div>
      <div style={S.idleHint}>Mengalihkan ke status pesanan...</div>
    </div>
  );
}

function CDSTracking({ state }) {
  const order = state.completedOrder || {};
  const currentStage = order.status || "waiting";
  const currentIdx = STAGES.findIndex(s => s.key === currentStage);

  return (
    <>
      <header style={S.header}>
        <div style={S.headerLeft}>
          <span style={S.logoSmall}>☕</span>
          <span style={S.brandSmall}>BINTORO</span>
        </div>
        <div style={S.tag}>Order #{order.id}</div>
      </header>

      <main style={S.trackMain}>
        <div style={S.trackTitle}>Status Pesanan Anda</div>
        <div style={S.trackSubtitle}>
          {order.customerName ? `Untuk ${order.customerName}` : "Customer"}
        </div>

        <div style={S.stagesContainer}>
          {STAGES.map((stage, idx) => {
            const isActive = idx === currentIdx;
            const isPast = idx < currentIdx;
            const color = isActive ? stage.color : isPast ? stage.color : "#333";
            return (
              <div key={stage.key} style={S.stageRow}>
                <div style={{...S.stageOrb, background: color, boxShadow: isActive ? `0 0 30px ${color}` : "none"}}>
                  <span style={{fontSize:isActive?42:28}}>{stage.emoji}</span>
                </div>
                <div style={{...S.stageLabel, color: isActive ? "#fff" : isPast ? "#888" : "#444",
                  fontWeight: isActive ? 800 : 600}}>
                  {stage.label}
                </div>
                {idx < STAGES.length - 1 && (
                  <div style={{...S.stageConnector, background: isPast ? stage.color : "#222"}}/>
                )}
              </div>
            );
          })}
        </div>

        <div style={S.trackHint}>
          {currentIdx === 0 && "Pesanan sedang diterima"}
          {currentIdx === 1 && "Pesanan sedang disiapkan koki"}
          {currentIdx === 2 && "🎉 Pesanan siap diambil di counter!"}
          {currentIdx === 3 && "Terima kasih, sampai jumpa lagi!"}
        </div>
      </main>
    </>
  );
}

